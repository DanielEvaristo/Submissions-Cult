// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum AccountType {
  ARTIST
  INDUSTRY
}

enum LabelStatus {
  PENDING_VERIFICATION
  APPROVED
  REJECTED
}

enum AdminRole {
  SUPER_ADMIN
  CURATOR
  MASTER_CURATOR
}

enum RoleType {
  ARTIST
  BAND
  MANAGEMENT
  PR
  AGENCY
}

enum AgeRange {
  UNDER_18
  AGE_18_24
  AGE_25_34
  AGE_35_44
  AGE_45_PLUS
}

enum ReleaseType {
  SINGLE
  EP
  ALBUM
}

enum StreamingPlatform {
  SPOTIFY
  SOUNDCLOUD
  DEEZER
  OTHER
}

enum Opportunity {
  WEEKLY
  SPOTIFY
  WEBRADIO
  ALBUM_STORY
}

enum Theme {
  DARK
  LIGHT
}

enum AccountStatus {
  ACTIVE          // cuenta completamente activa
  PENDING_CLAIM   // importada desde legacy — sin contraseña, esperando reclamación
  SUSPENDED       // suspendida por el admin
}

enum UILanguage {
  EN
  ES
  FR
}

enum ListenersRange {
  UNDER_1K
  FROM_1K_TO_10K
  FROM_10K_TO_50K
  FROM_50K_TO_100K
  FROM_100K_TO_500K
  OVER_500K
}

enum FollowersRange {
  UNDER_1K
  FROM_1K_TO_10K
  FROM_10K_TO_50K
  FROM_50K_TO_100K
  FROM_100K_TO_500K
  OVER_500K
}

enum Status {
  AWAITING_PAYMENT   // created but payment not confirmed yet
  PENDING            // just submitted, waiting for curator
  IN_REVIEW          // curator is reviewing
  CURATOR_APPROVED   // curator approved → auto-moves to MASTER_REVIEW
  CURATOR_REJECTED   // curator rejected → end of flow
  MASTER_REVIEW      // master curator reviewing
  ACCEPTED           // master accepted → placement assigned
  REJECTED           // master rejected → end of flow
  PUBLISHED          // master published → link provided
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum CreativeType {
  PHOTOGRAPHER
  WRITER
  DESIGNER
  VIDEOGRAPHER
  FAN
  OTHER
}

enum CreativeRequestStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}

enum PremiumPrStatus {
  NONE
  REQUESTED
  APPROVED
  PAID
  REJECTED
}

enum BugReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── NextAuth Tables ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  type      NotificationType @default(INFO)
  link      String?          // optional link to redirect when clicked
  isRead    Boolean          @default(false)
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Tables ────────────────────────────────────────────────────────────

model Admin {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // hashed with bcrypt
  
  role          AdminRole @default(CURATOR)
  assignedGenres String[] @default([])

  theme         Theme      @default(DARK)
  language      UILanguage @default(EN)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations for curation
  curatedSubmissions       Submission[] @relation("CuratorSubmissions")
  masterCuratedSubmissions Submission[] @relation("MasterCuratorSubmissions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // hashed with bcrypt — null for OAuth users

  // Account type
  accountType AccountType @default(ARTIST)

  // ── ARTIST fields ──────────────────────────────────────────────
  artistName String?
  roleType   RoleType @default(ARTIST) // ARTIST|BAND|MANAGEMENT|PR|AGENCY

  country String? // ISO 3166-1 alpha-2 code e.g. 'MX', 'US', 'FR'
  state   String?
  city    String?
  bio     String? // max 500 chars

  // Genre & subgenre
  genre    String?
  subgenre String?

  // Age range
  ageRange        AgeRange? // solo artist
  memberAgeRanges Json? // band: [{slot:1, range:'18_24'}, ...]
  bandSize        Int?

  // Social links
  spotifyUrl    String?
  instagram     String?
  tiktok        String?
  youtube       String?
  soundcloudUrl String?
  website       String?

  // Language of music creation
  musicLanguages String[] // e.g. ['en', 'es'] — ISO 639-1 codes

  // Career & industry info
  careerStartYear    Int? // year they started (for 'years active' calc)
  monthlyListeners   ListenersRange? // enum range, not exact number
  instagramFollowers FollowersRange?

  hasManager         Boolean             @default(false)

  // ── INDUSTRY fields ────────────────────────────────────────────
  legalName       String?
  websiteUrl      String?
  labelInstagram  String?
  isVerifiedLabel Boolean     @default(false)
  labelStatus     LabelStatus @default(PENDING_VERIFICATION)
  rejectionReason String?

  // UI preferences
  theme    Theme      @default(DARK)
  language UILanguage @default(EN)

  // Account status (ACTIVE by default, PENDING_CLAIM for legacy imports)
  accountStatus AccountStatus @default(ACTIVE)

  // Phase 2 — credits (schema-ready, no logic in MVP)
  credits      Int     @default(0)
  firstSubUsed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Own relations
  submissions        Submission[]
  donations          Donation[]
  creditTransactions CreditTransaction[]
  managedArtists     ManagedArtist[]
  notifications      Notification[]
  bugReports         BugReport[]
}

model ManagedArtist {
  id String @id @default(cuid())

  industryUserId String
  industryUser   User   @relation(fields: [industryUserId], references: [id])

  artistName String
  genre      String?
  subgenre   String?
  spotifyUrl String?
  instagram  String?
  notes      String?

  createdAt DateTime @default(now())

  // Submissions sent on behalf of this artist
  submissions Submission[]
}

model Submission {
  id String @id @default(cuid())

  userId String // who submitted (artist or industry user)
  user   User   @relation(fields: [userId], references: [id])

  // If submitted by an Industry account on behalf of a managed artist:
  managedArtistId String?
  managedArtist   ManagedArtist? @relation(fields: [managedArtistId], references: [id])

  artistName  String
  trackTitle  String
  releaseType ReleaseType
  releaseDate String?

  streamingUrl      String
  streamingPlatform StreamingPlatform?

  spotifyUrl String? // artist spotify profile
  instagram  String? // artist instagram handle

  genres    String[]
  subgenres String[]
  pitch     String? // max 1000 chars
  pressKitUrl String?
  senderName  String? // nombre del contacto (para importaciones legacy)

  opportunity Opportunity?

  // ── NEW FLOW FIELDS ──
  channels        String[] // e.g. ["RADAR", "INTERNET_WAVE", "SPOTIFY_PLAYLIST", "STORIES"]
  fastTrack         Boolean   @default(false)
  fastTrackDeadline DateTime? // Set to submittedAt + 48h when fastTrack = true
  reviewRequested   Boolean   @default(false)
  premiumServices String[] // e.g. ["INTERVIEW", "ARTICLE"]
  premiumPrStatus PremiumPrStatus @default(NONE)
  premiumPaymentLink String?
  assignedPremiumServices String[] @default([]) // e.g. ["INTERVIEW", "ARTICLE"]
  premiumServicesPaid     Boolean  @default(false)
  premiumPaymentIntentId  String?
  totalCostUsd    Int      @default(0) // cost in cents if paid via Stripe

  // Auto-fill metadata from streaming URL (populated server-side after URL parse)
  autoFilledTitle  String?
  autoFilledArtist String?
  autoFilledCover  String? // cover image URL from API
  autoFillSource   String? // which API was used

  // Curation flow — two levels
  status Status @default(PENDING)

  // Level 1 — Curator
  curatorId         String?
  curator           Admin?   @relation("CuratorSubmissions", fields: [curatorId], references: [id])
  curatorNotes      String?
  curatorRating     Int? // 1-5 stars
  curatorReviewedAt DateTime?

  // Level 2 — Master Curator
  masterCuratorId  String?
  masterCurator    Admin?   @relation("MasterCuratorSubmissions", fields: [masterCuratorId], references: [id])
  masterNotes      String?
  masterRating     Int? // 1-5 stars
  placement        String?
  publicationUrl   String?  // link to the published placement (Instagram, etc.)
  interviewUrl     String?  // link to the published interview
  articleUrl       String?  // link to the published article
  publishedAt      DateTime?
  masterReviewedAt DateTime?

  // Phase 2 ready
  creditsUsed Int     @default(0)
  isFree      Boolean @default(true)

  submittedAt DateTime @default(now())
}

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount    Int      // positive for purchase, negative for usage
  type      String   // PURCHASE | USAGE
  credits   Int      // number of credits involved
  currency  String   @default("usd")
  
  stripeSessionId String? @unique
  
  createdAt DateTime @default(now())
}

model Donation {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  amount   Int    // in cents (USD)
  currency String @default("usd")

  stripePaymentIntentId String @unique
  status                String // succeeded | pending | failed

  donorName  String?
  donorEmail String?

  createdAt DateTime @default(now())
}

// ─── Funnel Analytics ────────────────────────────────────────────────────────

model FunnelEvent {
  id        String   @id @default(cuid())

  // Anonymous identifier stored in the browser (localStorage)
  sessionId String

  // Which step they reached: 1 = Track Details, 2 = Opportunity, 3 = Confirm
  step      Int

  // true = user completed and submitted; false = reached step but didn't continue
  completed Boolean  @default(false)

  // Optional context
  opportunity String? // filled when step >= 2
  locale      String?

  createdAt DateTime @default(now())
}

// ─── Creative Collaboration Requests ─────────────────────────────────────────

model CreativeRequest {
  id   String @id @default(cuid())

  // Submitter info (no auth required — public form)
  name  String
  email String

  creativeType  CreativeType
  portfolioUrl  String?
  message       String       @db.Text

  status        CreativeRequestStatus @default(PENDING)

  // Internal review fields
  adminNotes    String?      @db.Text
  reviewedById  String?      // Admin.id who reviewed it (not a FK to avoid coupling)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Bug Reports ─────────────────────────────────────────────────────────────

model BugReport {
  id          String          @id @default(cuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  description String          @db.Text
  url         String?         // The URL where the bug occurred
  status      BugReportStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  adminNotes  String?         @db.Text
}
