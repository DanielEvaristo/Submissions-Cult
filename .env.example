# Copy this file to .env.local and fill in the values

# Database (Docker Compose sets this automatically in production)
DATABASE_URL=postgresql://cm_user:devpassword@localhost:5432/cm_submissions
POSTGRES_PASSWORD=changeme

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Stripe (use test keys locally: sk_test_... pk_test_...)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
RESEND_API_KEY=re_...
EMAIL_FROM=submissions@cult-machine.com

# Spotify (for auto-fill)
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# Ko-fi
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/cultmachine

# i18n
NEXT_PUBLIC_DEFAULT_LOCALE=en
