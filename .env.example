# ── Cult Machine Portal — Environment Variables ──────────────────────────────
# Copy this file to .env.local for local development.
# For Railway: set these in the Railway dashboard → Variables tab.
# NEVER commit real secrets to git.

# ── Database ─────────────────────────────────────────────────────────────────
# Local: use docker-compose.dev.yml credentials
# Railway: auto-provisioned — use the DATABASE_URL from Railway's PostgreSQL plugin
DATABASE_URL=postgresql://cm_user:devpassword@localhost:5432/cm_submissions
POSTGRES_PASSWORD=changeme

# ── NextAuth ─────────────────────────────────────────────────────────────────
# NEXTAUTH_URL: your public domain (Railway gives you https://xxx.up.railway.app)
NEXTAUTH_URL=http://localhost:3000

# IMPORTANT: Generate a strong secret for production!
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
# Linux/Mac:  openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use TEST keys (sk_test_... / pk_test_...) for development and testing
# Switch to LIVE keys (sk_live_... / pk_live_...) only for real production
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Development: use onboarding@resend.dev (no domain verification needed)
# Production: verify your domain in resend.com, then use submissions@cult-machine.com
EMAIL_FROM=Cult Machine <onboarding@resend.dev>
# Remove EMAIL_TEST_OVERRIDE when your domain is verified in Resend
# EMAIL_TEST_OVERRIDE=your-email@gmail.com

# ── Spotify (auto-fill track info) ──────────────────────────────────────────
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# ── Ko-fi ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/cultmachine

# ── i18n ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ── OpenAI (optional — for AI features) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
