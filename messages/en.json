    "faq": {
      "item1": {
        "q": "HOW LONG DOES IT TAKE TO GET A RESPONSE?",
        "a": "With free submissions, we will respond within 7 days. If you use the Fast Response Add-on, we guarantee a reply in under 48 hours."
      },
      "item2": {
        "q": "WHAT GENRES DO YOU COVER?",
        "a": "We accept all genres, as long as they have a young audience, but without a doubt our favorites are alternative genres."
      },
      "item3": {
        "q": "IS IT REALLY FREE?",
        "a": "Yes, all submissions are free. We believe in the community and that is why we have made it free, although you can enhance your experience for a lower price, and all the money is destined to keep growing."
      },
      "item4": {
        "q": "HOW DOES PREMIUM PR WORK?",
        "a": "Premium PR is an invite-only tier. If you meet the requirements (over 10k followers on Instagram or Spotify), our team can work with you on exclusive interviews and dedicated articles to further push your releases."
      }
    }
